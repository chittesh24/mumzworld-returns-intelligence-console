__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
venv/
.venv/
env/

# FastAPI / local db
*.sqlite3

# Node / Next.js
node_modules/
.next/
out/
dist/
coverage/

# TypeScript
*.tsbuildinfo

# IDEs
.vscode/
.idea/

# Temporary files
*.tmp
*.temp
*.swp

# Uploads / generated assets
uploads/
screenshots/
recordings/

# Mac / Linux metadata
.AppleDouble
.LSOverride